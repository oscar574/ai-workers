{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string"
    },
    "contact_id": {
      "type": "string"
    },
    "ai_employee_id": {
      "type": "string"
    },
    "channel": {
      "type": "string",
      "enum": [
        "test_chat",
        "whatsapp",
        "web"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "expired"
      ],
      "default": "open"
    },
    "human_handoff_required": {
      "type": "boolean",
      "default": false
    },
    "summary": {
      "type": "string"
    }
  },
  "required": [
    "organization_id",
    "contact_id"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.organization_id": "{{user.data.organization_id}}"
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.organization_id": "{{user.data.organization_id}}"
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.organization_id": "{{user.data.organization_id}}"
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.organization_id": "{{user.data.organization_id}}"
        },
        {
          "user_condition": {
            "role": "super_admin"
          }
        }
      ]
    }
  }
}